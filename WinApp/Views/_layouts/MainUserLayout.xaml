<UserControl x:Class="WinApp.Views.MainUserLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinApp.Views"
             xmlns:vst="clr-namespace:Vst.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border x:Name="Banner"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="0 0 0 1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="24 0 18 0" VerticalAlignment="Center">
                    <Label Content="Thủy lợi" 
                           Padding="0"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold" />
                    <Label Content="Quản lý công trình" 
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="12"
                           Padding="0" />
                </StackPanel>

                <local:AppMainMenu Grid.Column="1"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   x:Name="TopMenu" />

                <vst:HorizontalMenu Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0 0 20 0"
                                    x:Name="UserActions">
                    <vst:Button x:Name="MeButton"
                                Padding="12 8"
                                BorderRadius="10"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="#B7D9FF"
                                Foreground="{StaticResource AccentBrush}"
                                Width="120"
                                Height="36" />
                </vst:HorizontalMenu>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="#F2F2F7"
                    BorderBrush="{StaticResource BorderSoftBrush}"
                    BorderThickness="0 0 1 0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <vst:VerticalMenu x:Name="SideMenu" Background="Transparent" />
                </ScrollViewer>
            </Border>

            <Border x:Name="Body"
                    Grid.Column="2"
                    Margin="26 20 32 32"
                    Background="Transparent">
            </Border>
        </Grid>
    </Grid>
</UserControl>
