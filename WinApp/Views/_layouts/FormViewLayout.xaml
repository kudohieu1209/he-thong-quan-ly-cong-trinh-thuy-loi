<UserControl x:Class="WinApp.Views.FormViewLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vst="clr-namespace:Vst.Controls"
             mc:Ignorable="d" 
             HorizontalAlignment="Center"
             VerticalAlignment="Center"
             d:DesignHeight="450" Width="640">
    <UserControl.Resources>
    </UserControl.Resources>
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderSoftBrush}"
            BorderThickness="1"
            CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              Direction="270"
                              ShadowDepth="2"
                              Opacity="0.12"
                              Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition />
                <RowDefinition Height="64" />
            </Grid.RowDefinitions>

            <Border BorderThickness="0 0 0 1" 
                    BorderBrush="#EEF0F2" 
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="16 16 0 0">
                <TextBlock VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="24 0"
                           FontWeight="SemiBold"
                           FontSize="24"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           x:Name="Title">TITLE</TextBlock>
            </Border>

            <Border x:Name="Body"
                    Grid.Row="1"
                    Padding="24"
                    Background="{StaticResource SurfaceBrush}">
                <Grid />
            </Border>

            <Border x:Name="Footer" Grid.Row="2" 
                    BorderThickness="0 1 0 0"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="#EEF0F2"
                    CornerRadius="0 0 16 16">
                <StackPanel x:Name="ActionPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="24 0">
                    <vst:Button x:Name="CancelButton" 
                                Text="Hủy"
                                Visibility="Collapsed"
                                Background="#FFFFFF"
                                BorderBrush="{StaticResource BorderSoftBrush}"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Width="96" Height="38"
                                BorderRadius="10"/>
                    <vst:Button x:Name="DenyButton" 
                                Text="Xóa" 
                                Visibility="Collapsed"
                                Background="#FF3B30"
                                BorderBrush="#FF3B30"
                                Foreground="#FFFFFF"
                                Width="96" Height="38"
                                BorderRadius="10"/>
                    <vst:Button x:Name="AcceptButton" 
                                Text="Xác nhận" 
                                Width="112" Height="38"
                                BorderRadius="10"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
