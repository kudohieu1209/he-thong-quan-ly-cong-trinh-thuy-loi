<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Waterworks.Maui.Views.CongTrinhListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shared="clr-namespace:Waterworks.Shared;assembly=Waterworks.Shared"
    Title="Cong trinh">
    <Grid Padding="14" RowDefinitions="Auto,*" RowSpacing="12">
        <HorizontalStackLayout Spacing="8">
            <Button Text="Them" Clicked="OnAddClicked" />
            <Button Text="Tai lai" Clicked="OnRefreshClicked" />
        </HorizontalStackLayout>
        <CollectionView
            x:Name="CongTrinhCollection"
            Grid.Row="1"
            SelectionMode="Single"
            SelectionChanged="OnSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="shared:CongTrinhDto">
                    <Grid Padding="10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                        <Label Text="{Binding TenCongTrinh}" FontAttributes="Bold" />
                        <Label Grid.Row="1" Text="{Binding MaHieu}" TextColor="#64748B" />
                        <Label Grid.Row="2" Text="{Binding DiaDiem}" TextColor="#475569" />
                        <Button
                            Grid.Column="1"
                            Grid.RowSpan="3"
                            Text="Xoa"
                            Clicked="OnDeleteClicked"
                            CommandParameter="{Binding Id}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
