<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Waterworks.Maui.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Home">
    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="12">
            <Label x:Name="WelcomeLabel" FontSize="22" FontAttributes="Bold" />
            <Button Text="Mo danh sach cong trinh" Clicked="OnOpenCongTrinhClicked" />
            <Label Text="Menu" FontSize="18" FontAttributes="Bold" Margin="0,12,0,0" />
            <VerticalStackLayout x:Name="MenuLayout" Spacing="8" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
