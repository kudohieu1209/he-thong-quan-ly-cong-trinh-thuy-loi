<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Waterworks.Maui.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Login">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14" VerticalOptions="Center">
            <Label Text="Waterworks" FontSize="28" FontAttributes="Bold" />
            <Label Text="Dang nhap de quan ly cong trinh thuy loi" TextColor="#475569" />
            <Entry x:Name="UserNameEntry" Placeholder="Ten dang nhap" Text="admin" />
            <Entry x:Name="PasswordEntry" Placeholder="Mat khau" IsPassword="True" Text="1234" />
            <Button Text="Dang nhap" Clicked="OnLoginClicked" />
            <Label x:Name="MessageLabel" TextColor="#B91C1C" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
