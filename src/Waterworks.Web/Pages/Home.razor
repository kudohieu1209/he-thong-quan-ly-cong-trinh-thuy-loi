@page "/"
@inject ApiClient Api
@inject SessionState Session

<PageTitle>Home</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">MVP quan ly cong trinh thuy loi</p>
        <h1>Waterworks</h1>
        <p>Web client dung chung backend API voi MAUI Android/Windows.</p>
    </div>
    <NavLink class="primary-button" href="congtrinh">Mo danh sach cong trinh</NavLink>
</section>

<div class="stat-grid">
    <div class="stat-card">
        <span>Trang thai</span>
        <strong>@(Session.IsAuthenticated ? "Da dang nhap" : "Chua dang nhap")</strong>
    </div>
    <div class="stat-card">
        <span>Tai khoan</span>
        <strong>@(Session.CurrentUser?.UserName ?? "---")</strong>
    </div>
    <div class="stat-card">
        <span>Vai tro</span>
        <strong>@(Session.CurrentUser?.Role ?? "---")</strong>
    </div>
</div>

<section class="panel">
    <h2>Menu</h2>
    @if (menu is null)
    {
        <p>Dang tai menu...</p>
    }
    else
    {
        <div class="menu-grid">
            @foreach (var group in menu)
            {
                <div class="menu-group">
                    <h3>@group.Title</h3>
                    @foreach (var item in group.Items)
                    {
                        <p>@item.Title</p>
                    }
                </div>
            }
        </div>
    }
</section>

@code {
    private IReadOnlyList<MenuGroupDto>? menu;

    protected override async Task OnInitializedAsync()
    {
        menu = await Api.GetMenuAsync();
    }
}
