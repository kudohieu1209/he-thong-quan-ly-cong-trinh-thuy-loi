@page "/login"
@inject ApiClient Api
@inject SessionState Session
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<section class="auth-shell">
    <div class="auth-panel">
        <p class="eyebrow">Waterworks API</p>
        <h1>Dang nhap</h1>
        <label>
            Ten dang nhap
            <input @bind="userName" />
        </label>
        <label>
            Mat khau
            <input type="password" @bind="password" />
        </label>
        <button class="primary-button" @onclick="LoginAsync" disabled="@isBusy">
            @(isBusy ? "Dang dang nhap..." : "Dang nhap")
        </button>
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="error-text">@message</p>
        }
    </div>
</section>

@code {
    private string userName = "admin";
    private string password = "1234";
    private string? message;
    private bool isBusy;

    private async Task LoginAsync()
    {
        isBusy = true;
        message = null;

        try
        {
            var user = await Api.LoginAsync(userName, password);
            if (user is null)
            {
                message = "Sai ten dang nhap hoac mat khau.";
                return;
            }

            Session.SetUser(user);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            message = $"Khong ket noi duoc API: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }
}
